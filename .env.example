SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Allow all subdomains of newnepal.workers.dev
CORS_ALLOWED_ORIGIN_REGEXES=^https://[a-zA-Z0-9-]+\.newnepal\.workers\.dev$
# For browser cookie-based writes from workers.dev subdomains
CSRF_TRUSTED_ORIGINS=https://*.newnepal.workers.dev
NES_API_URL=https://nes.jawafdehi.org/api
DATABASE_URL=postgresql://user:password@localhost:5432/jawafdehi
NGM_DATABASE_URL=postgresql://user:password@localhost:5432/ngm
NGM_QUERY_MAX_ROWS=500

# NES Queue System (only needed for GitHub Actions queue processing)
# NES_DB_PATH=/path/to/nes-db


# File Storage Configuration (optional in development, required for production)
# Leave blank to use local FileSystemStorage (development)
# Set these to use S3-compatible storage (AWS S3, Cloudflare R2, Minio, etc.)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=jawafdehi
# AWS_S3_REGION_NAME=auto (for Cloudflare R2) or us-east-1 (for AWS)
# AWS_S3_ENDPOINT_URL=https://your-endpoint-url (for Cloudflare R2 or Minio)
# AWS_S3_USE_SSL=True (for remote storage)
# FILE_HASH_SALT=your-secure-salt-for-file-hashing
# FILE_STORAGE_PREFIX=case_uploads/ (prefix for uploaded files)
# MEDIA_URL=/media/ (URL path for media files)
# MEDIA_ROOT=/path/to/media (filesystem path for local storage)


# Case Workflow Configuration
# API token for the Jawafdehi MCP server (jawafdehi-mcp)
# JAWAFDEHI_API_TOKEN=your-jawafdehi-api-token

# Public Chat MCP Configuration
# Uses the same stdio MCP server shape as workflows by default:
# uvx --from git+https://github.com/Jawafdehi/jawafdehi-mcp.git jawafdehi-mcp
# Public chat does not pass JAWAFDEHI_API_TOKEN to MCP.
# PUBLIC_CHAT_MCP_API_BASE_URL=http://127.0.0.1:8000
# Optional: set PUBLIC_CHAT_MCP_SERVERS_JSON to fully override the MCP server
# config from the environment for temporary development.

# Case Workflow LLM Configuration# Model in provider:model format (default: openai:gpt-4o)
# JAWAFDEHI_CASEWORK_MODEL=openai:gpt-4o
# API key for the LLM provider (falls back to provider-specific env var, e.g. OPENAI_API_KEY)
# JAWAFDEHI_CASEWORK_API_KEY=your-api-key
# Base URL for OpenAI-compatible endpoints (e.g. Ollama)
# JAWAFDEHI_CASEWORK_BASE_URL=http://localhost:11434/v1


# Langfuse Observability (optional — traces LLM calls during workflow execution)
# Get your keys at https://cloud.langfuse.com or your self-hosted instance
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
