SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
NES_API_URL=https://nes.newnepal.org/api
DATABASE_URL=postgresql://user:password@localhost:5432/jawafdehi

# NES Queue System (only needed for GitHub Actions queue processing)
# NES_DB_PATH=/path/to/nes-db

# File Storage Configuration (optional in development, required for production)
# Leave blank to use local FileSystemStorage (development)
# Set these to use S3-compatible storage (AWS S3, Cloudflare R2, Minio, etc.)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=jawafdehi
# AWS_S3_REGION_NAME=auto (for Cloudflare R2) or us-east-1 (for AWS)
# AWS_S3_ENDPOINT_URL=https://your-endpoint-url (for Cloudflare R2 or Minio)
# AWS_S3_USE_SSL=True (for remote storage)
# MEDIA_URL=/media/ (URL path for media files)
# MEDIA_ROOT=/path/to/media (filesystem path for local storage)
