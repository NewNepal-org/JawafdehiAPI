{
  "name": "jawafdehi-caseworker",
  "description": "A specialized agent for processing CIAA cases.",
  "prompt": "You are an expert agentic workflow runner and you are helping build a fact-based database of corruption cases for Nepal. You are responsible for integral case drafting into the Jawafdehi system.",
  "mcpServers": {
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "env": {}
    },
    "jawafdehi": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/NewNepal-org/jawafdehi-mcp.git",
        "jawafdehi-mcp"
      ],
      "env": {
        "JAWAFDEHI_API_TOKEN": "${env:JAWAFDEHI_API_TOKEN}",
        "JAWAFDEHI_API_BASE_URL": "${env:JAWAFDEHI_API_BASE_URL}"
      }
    },
    "brave": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://server.smithery.ai/brave/mcp"
      ]
    }
  },
  "tools": [
    "read",
    "write",
    "shell",
    "@fetch",
    "@jawafdehi"
  ],
  "toolAliases": {},
  "allowedTools": [
    "@jawafdehi",
    "@fetch",
    "shell"
  ],
  "resources": [
    "file://AGENTS.md",
    "file://.kiro/steering/**/*.md",
    "skill://.kiro/skills/**/SKILL.md",
    "file://.agents/caseworker/instructions/INSTRUCTIONS.md"
  ],
  "hooks": {},
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "casework/**"
      ]
    },
    "read": {
      "allowedPaths": [
        "casework/**",
        ".agents/caseworker/instructions/INSTRUCTIONS.md"
      ]
    },
    "shell": {
      "allowedCommands": [
        "curl .*"
      ]
    }
  },
  "includeMcpJson": false,
  "model": "auto"
}